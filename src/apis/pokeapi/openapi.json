{
  "openapi": "3.0.0",
  "info": {
    "title": "PokeAPI",
    "version": "v2",
    "description": "All the Pokémon data you'll ever need in one place."
  },
  "paths": {
    "/pokemon/{name}": {
      "get": {
        "summary": "Get Pokémon by Name",
        "description": "Returns detailed information about a specific Pokémon.",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "description": "The name or ID of the Pokémon to retrieve.",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "integer" },
                    "name": { "type": "string" },
                    "base_experience": { "type": "integer" }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Pokémon not found"
          }
        }
      }
    },
    "/pokemon": {
      "get": {
        "summary": "List Pokémon",
        "description": "Paginated endpoint to retrieve a list of multiple Pokémon instantly.",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "description": "Maximum number of Pokémon to return",
            "schema": { "type": "integer", "default": 20 }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "description": "Number of Pokémon to skip",
            "schema": { "type": "integer", "default": 0 }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of Pokémon",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "count": { "type": "integer" },
                    "results": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": { "type": "string" },
                          "url": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/pokemon/favorites": {
      "post": {
        "summary": "Simulated: Add to Favorites",
        "description": "A demo-only endpoint to test POST requests and JSON bodies in the sandbox.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "pokemon_name": { "type": "string" },
                  "notes": { "type": "string" },
                  "is_primary": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Simulated: Successfully added to favorites",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "message": { "type": "string" },
                    "mock_id": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
